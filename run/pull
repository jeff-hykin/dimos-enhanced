#!/usr/bin/env -S deno run --allow-all
// @ts-check
import $ from "https://esm.sh/dax-sh@0.42.0"
import { resolve, dirname, join } from "https://esm.sh/path-browserify@1.0.1"

const enhanceDir = resolve(dirname(new URL(import.meta.url).pathname), "..")
const itemsDir = join(enhanceDir, "items")
const parentDir = dirname(enhanceDir) // the repo that contains .ignore.enhance

// Pull latest from remote
const pullResult = await $`git -C ${enhanceDir} pull`.noThrow()
if (pullResult.code !== 0) {
    Deno.exit(pullResult.code)
}

// Walk items/ and create symlinks in the parent repo, collecting all leaf file paths
const leafPaths = []
await linkItem(itemsDir, parentDir)

// Resolve the actual git dir (handles worktrees where .git is a file)
let gitDir = join(parentDir, ".git")
try {
    const stat = await Deno.stat(gitDir)
    if (!stat.isDirectory) {
        // .git is a file (worktree) — read the gitdir pointer
        const content = await Deno.readTextFile(gitDir)
        const match = content.match(/gitdir:\s*(.+)/)
        if (match) {
            const resolved = match[1].trim()
            gitDir = resolved.startsWith("/") ? resolved : resolve(parentDir, resolved)
        }
    }
} catch { /* .git doesn't exist at all */ }

// Ensure every leaf file path is git-excluded
const excludePath = join(gitDir, "info", "exclude")
let excludeContent = ""
try {
    excludeContent = await Deno.readTextFile(excludePath)
} catch { /* file might not exist */ }

let changed = false
for (const relPath of leafPaths) {
    if (!excludeContent.split("\n").some(line => line.trim() === relPath)) {
        excludeContent += `\n${relPath}`
        changed = true
    }
}
if (changed) {
    // Ensure info/ directory exists
    try { await Deno.mkdir(join(gitDir, "info"), { recursive: true }) } catch { /* exists */ }
    await Deno.writeTextFile(excludePath, excludeContent.replace(/\n{3,}/g, "\n\n") + "\n")
    console.log(`Updated ${excludePath}`)
}

console.log("enhance pull complete")

// Recursively link files from srcDir into targetDir
// Directories are created (not symlinked) so tracked dirs like bin/ aren't replaced
async function linkItem(srcDir, targetDir) {
    try { await Deno.mkdir(targetDir, { recursive: true }) } catch { /* exists */ }
    for await (const entry of Deno.readDir(srcDir)) {
        const srcPath = join(srcDir, entry.name)
        const targetPath = join(targetDir, entry.name)
        if (entry.isDirectory) {
            await linkItem(srcPath, targetPath)
        } else {
            // Record the relative path from the parent repo root
            const relPath = targetPath.slice(parentDir.length + 1)
            leafPaths.push(relPath)

            // Create symlink (remove existing symlink first)
            try {
                const stat = await Deno.lstat(targetPath)
                if (stat.isSymlink) {
                    await Deno.remove(targetPath)
                } else {
                    console.warn(`  SKIP: ${relPath} exists and is not a symlink`)
                    continue
                }
            } catch { /* target doesn't exist, good */ }

            await Deno.symlink(srcPath, targetPath)
            console.log(`  linked ${relPath}`)
        }
    }
}
