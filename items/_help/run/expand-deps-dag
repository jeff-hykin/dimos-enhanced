#!/usr/bin/env python3

import argparse
import json
from pathlib import Path


def _load_dag(path: Path) -> dict[str, list[str]]:
    data = json.loads(path.read_text())
    if not isinstance(data, dict):
        raise ValueError("Input DAG must be a JSON object.")
    normalized = {}
    for key, value in data.items():
        if not isinstance(key, str) or not isinstance(value, list):
            raise ValueError("Each DAG entry must map a file path to a list.")
        normalized[key] = value
    return normalized


def _compute_indirect(dag: dict[str, list[str]], node: str) -> list[str]:
    direct = dag.get(node, [])
    seen: set[str] = set()
    stack = list(direct)
    while stack:
        dep = stack.pop()
        if dep in seen:
            continue
        seen.add(dep)
        if dep in dag:
            stack.extend(dag[dep])
    indirect = sorted(seen - set(direct))
    return indirect


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Expand a static dependency DAG into direct/indirect dependencies."
    )
    parser.add_argument(
        "--input",
        default="dimos_static_deps.json",
        help="Path to the base DAG JSON file.",
    )
    parser.add_argument(
        "--output",
        default="expanded_dag.json",
        help="Path to write the expanded DAG JSON file.",
    )
    args = parser.parse_args()

    input_path = Path(args.input)
    output_path = Path(args.output)

    dag = _load_dag(input_path)
    expanded = {}
    for node, direct in dag.items():
        expanded[node] = {
            "direct": list(direct),
            "indirect": _compute_indirect(dag, node),
        }

    output_path.write_text(json.dumps(expanded, indent=2, sort_keys=True))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
