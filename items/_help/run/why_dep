#!/usr/bin/env python3

import argparse
import json
from collections import deque
from pathlib import Path


def _load_dag(path: Path) -> dict[str, list[str]]:
    data = json.loads(path.read_text())
    if not isinstance(data, dict):
        raise ValueError("Input DAG must be a JSON object.")
    normalized: dict[str, list[str]] = {}
    for key, value in data.items():
        if not isinstance(key, str) or not isinstance(value, list):
            raise ValueError("Each DAG entry must map a file path to a list.")
        normalized[key] = value
    return normalized


def _matches_end(dep: str, end: str) -> bool:
    return dep == end or dep.startswith(f"{end}.")


def _find_path(dag: dict[str, list[str]], start: str, end: str, banned: set[str]) -> list[str] | None:
    queue = deque([start])
    parent: dict[str, str | None] = {start: None}
    found_end = None
    while queue:
        node = queue.popleft()
        if node == end:
            found_end = node
            break
        for dep in dag.get(node, []):
            if dep in banned and dep not in (start, end):
                continue
            if _matches_end(dep, end):
                parent[dep] = node
                found_end = dep
                queue.clear()
                break
            if dep not in parent:
                parent[dep] = node
                queue.append(dep)
    if not found_end:
        return None
    path = []
    cur: str | None = found_end
    while cur is not None:
        path.append(cur)
        cur = parent[cur]
    return list(reversed(path))


def _find_disjoint_paths(
    dag: dict[str, list[str]], start: str, end: str, limit: int
) -> list[list[str]]:
    paths: list[list[str]] = []
    banned: set[str] = set()
    while len(paths) < limit:
        path = _find_path(dag, start, end, banned)
        if not path:
            break
        paths.append(path)
        banned.update(path[1:-1])
    return paths


def main() -> int:
    parser = argparse.ArgumentParser(
        description="Find disjoint dependency paths between a file and a dependency."
    )
    parser.add_argument("start", help="Start node (file path key in the DAG).")
    parser.add_argument("end", help="End node (dependency name or file path).")
    parser.add_argument(
        "--dag",
        default="_help/dimos_static_deps.json",
        help="Path to the base DAG JSON file.",
    )
    parser.add_argument("--limit", type=int, default=10, help="Max number of paths to return.")
    args = parser.parse_args()

    dag = _load_dag(Path(args.dag))
    if args.start not in dag:
        raise SystemExit(f"Start node not found in DAG: {args.start}")

    paths = _find_disjoint_paths(dag, args.start, args.end, args.limit)
    print(json.dumps(paths, indent=2))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
