#!/usr/bin/env python3
"""Stream /odometry at ~5Hz with timestamps.

Usage:
    bin/get_pos
"""

import time

import lcm  # type: ignore[import-untyped]

from dimos.msgs.nav_msgs.Odometry import Odometry

TOPIC = "/odometry#nav_msgs.Odometry"
INTERVAL = 0.2  # 5 Hz


def main() -> None:
    lc = lcm.LCM()
    last_print = 0.0

    def handler(_channel: str, data: bytes) -> None:
        nonlocal last_print
        now = time.time()
        if now - last_print < INTERVAL:
            return
        last_print = now
        odom = Odometry.lcm_decode(data)
        p = odom.pose.position
        v = odom.twist.twist.linear
        t = now % 1000  # modulus timestamp
        print(f"[{t:07.3f}] pos=({p.x:+8.3f}, {p.y:+8.3f}, {p.z:+8.3f})  vel=({v.x:+6.3f}, {v.y:+6.3f}, {v.z:+6.3f})")

    lc.subscribe(TOPIC, handler)

    while True:
        lc.handle()


if __name__ == "__main__":
    main()
