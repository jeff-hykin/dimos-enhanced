#!/usr/bin/env python3
"""Publish a PointStamped on /clicked_point via LCM to set a navigation goal.

Usage:
    bin/send_clicked_point <x> <y> [z]
    bin/send_clicked_point 5.0 3.0        # goal at (5, 3, 0)
    bin/send_clicked_point 10.0 -2.0 1.5  # goal at (10, -2, 1.5)
"""

import sys
import time

import lcm  # type: ignore[import-untyped]

from dimos.msgs.geometry_msgs.PointStamped import PointStamped

TOPIC = "/clicked_point#geometry_msgs.PointStamped"


def main() -> None:
    if len(sys.argv) < 3:
        print(f"Usage: {sys.argv[0]} <x> <y> [z]")
        print("  e.g. 5.0 3.0      (goal at x=5, y=3)")
        print("  e.g. 10.0 -2.0 1.5")
        sys.exit(1)

    x = float(sys.argv[1])
    y = float(sys.argv[2])
    z = float(sys.argv[3]) if len(sys.argv) > 3 else 0.0

    pt = PointStamped(x=x, y=y, z=z, ts=time.time(), frame_id="map")

    lc = lcm.LCM()
    lc.publish(TOPIC, pt.lcm_encode())

    t = time.time() % 1000
    print(f"[{t:07.3f}] Published goal ({x}, {y}, {z}) on {TOPIC}")


if __name__ == "__main__":
    main()
