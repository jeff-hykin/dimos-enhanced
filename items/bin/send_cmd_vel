#!/usr/bin/env python3
"""Publish a Twist on /tele_cmd_vel via LCM.

Usage:
    bin/send_cmd_vel <linear_x> <linear_y> <angular_z>
    bin/send_cmd_vel 0.5 0 0        # forward
    bin/send_cmd_vel 0 0 0.5         # turn left
    bin/send_cmd_vel 0 0 0           # stop
"""

import sys
import time

import lcm  # type: ignore[import-untyped]

from dimos.msgs.geometry_msgs.Twist import Twist

TOPIC = "/tele_cmd_vel#geometry_msgs.Twist"


def main() -> None:
    if len(sys.argv) < 4:
        print(f"Usage: {sys.argv[0]} <linear_x> <linear_y> <angular_z>")
        print("  e.g. 0.5 0 0  (forward)  |  0 0 0.5  (turn left)  |  0 0 0  (stop)")
        sys.exit(1)

    lx, ly, az = float(sys.argv[1]), float(sys.argv[2]), float(sys.argv[3])
    twist = Twist([lx, ly, 0], [0, 0, az])

    lc = lcm.LCM()
    data = twist.lcm_encode()

    # Send a short burst so the mux registers it
    for _ in range(5):
        lc.publish(TOPIC, data)
        time.sleep(0.05)

    print(f"Published Twist(linear=[{lx}, {ly}, 0], angular=[0, 0, {az}]) on {TOPIC}")


if __name__ == "__main__":
    main()
