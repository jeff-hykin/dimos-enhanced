#!/usr/bin/env python3
"""Show first N rows OR first S seconds of an entity."""
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
import rrd_lib as L


def main():
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("file", help="Path to .rrd file")
    p.add_argument("--entity", required=True, help="Entity path")
    p.add_argument("-n", type=int, default=5, help="Number of rows (default: 5)")
    p.add_argument("--seconds", type=float, help="First S seconds instead of N rows")
    p.add_argument("--component", help="Include only this component")
    p.add_argument("--timeline", help="Timeline (default: log_time)")
    p.add_argument("--summary", action="store_true", help="Only include size/shape, not full values")
    args = p.parse_args()

    with L.open_rrd(args.file) as (_s, dataset):
        info = L.enumerate_columns(dataset)
        timeline = L.pick_timeline(info["index_columns"], args.timeline)
        df, tl = L.read_entity(dataset, args.entity, timeline=timeline)
        if len(df) == 0:
            L.emit_json({"entity": args.entity, "rows": []})
            return

        if args.seconds is not None and tl in df.columns:
            times = L.to_timeline_seconds(df[tl], tl).to_numpy()
            t0 = float(times[0])
            mask = times <= (t0 + args.seconds)
            selected = df[mask]
        else:
            selected = df.head(args.n)

        data_cols = [c for c in df.columns if ":" in c and not c.startswith("rerun_")]
        if args.component:
            data_cols = [c for c in data_cols if c.endswith(f":{args.component}")]

        rows = []
        for i in range(len(selected)):
            r = {"time": L.timestamp_to_iso(selected[tl].iloc[i]) if tl in selected.columns else None}
            for c in data_cols:
                vals = L.extract_values(selected[c][i:i+1])
                v = vals[0] if vals else None
                key = c.split(":", 1)[-1] if ":" in c else c
                r[key] = L.value_size(v) if args.summary else v
            rows.append(r)

    L.emit_json({"entity": args.entity, "timeline": tl, "total_rows_in_entity": len(df), "rows": rows})


if __name__ == "__main__":
    main()
