#!/usr/bin/env python3
"""Show full component schema grouped by archetype."""
import argparse
import sys
from collections import defaultdict
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
import rrd_lib as L


def main():
    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("file", help="Path to .rrd file")
    args = p.parse_args()

    with L.open_rrd(args.file) as (_server, dataset):
        info = L.enumerate_columns(dataset)

    by_archetype: dict[str, list[dict]] = defaultdict(list)
    for col in info["component_columns"]:
        by_archetype[col["archetype"]].append({
            "entity_path": col["entity_path"],
            "component": col["component"],
            "component_type": col["component_type"],
            "is_static": col["is_static"],
        })

    result = {
        "timelines": info["index_columns"],
        "archetypes": {arch: sorted(cols, key=lambda c: (c["entity_path"], c["component"])) for arch, cols in sorted(by_archetype.items())},
    }
    L.emit_json(result)


if __name__ == "__main__":
    main()
