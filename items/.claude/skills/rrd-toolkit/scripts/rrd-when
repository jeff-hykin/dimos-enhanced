#!/usr/bin/env python3
"""List timestamps where a predicate over a component holds.

Examples:
  rrd-when file.rrd --entity /world/odom --component Transform3D:translation --predicate 'norm(value - [0,2,6]) < 1.0'
  rrd-when file.rrd --entity /world/lidar --component Points3D:positions --predicate 'size > 10000'
  rrd-when file.rrd --entity /world/odom --component Transform3D:translation --predicate 'z < 0.5'
"""
import argparse
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).parent))
import rrd_lib as L


def main():
    p = argparse.ArgumentParser(description=__doc__, formatter_class=argparse.RawDescriptionHelpFormatter)
    p.add_argument("file", help="Path to .rrd file")
    p.add_argument("--entity", required=True, help="Entity path")
    p.add_argument("--component", required=True, help="Component")
    p.add_argument("--predicate", required=True, help="Boolean expression (see references/predicate_syntax.md)")
    p.add_argument("--timeline", help="Timeline (default: log_time)")
    p.add_argument("--max-matches", type=int, default=1000, help="Cap on matches (default: 1000)")
    p.add_argument("--values", action="store_true", help="Include full component values (off by default for brevity)")
    args = p.parse_args()

    with L.open_rrd(args.file) as (_s, dataset):
        info = L.enumerate_columns(dataset)
        timeline = L.pick_timeline(info["index_columns"], args.timeline)
        df, tl = L.read_entity(dataset, args.entity, timeline=timeline)
        if len(df) == 0:
            L.emit_json({"entity": args.entity, "matches": []})
            return

        col = L.component_column_name(df, args.entity, args.component)
        if col is None:
            print(f"ERROR: component '{args.component}' not found for {args.entity}", file=sys.stderr)
            sys.exit(2)

        try:
            code = L.compile_predicate(args.predicate)
        except ValueError as e:
            print(f"ERROR: {e}", file=sys.stderr)
            sys.exit(2)

        vals = L.extract_values(df[col])
        matches = []
        for i, v in enumerate(vals):
            size = L.value_size(v)
            if L.eval_predicate(code, v, size):
                row_t = float(L.to_timeline_seconds(df[tl], tl).iloc[i]) if tl in df.columns else None
                match = {
                    "index": i,
                    "time": row_t,
                    "size": size,
                }
                if args.values:
                    match["value"] = v
                matches.append(match)
                if len(matches) >= args.max_matches:
                    break

    L.emit_json({
        "entity": args.entity,
        "component": args.component,
        "predicate": args.predicate,
        "timeline": tl,
        "num_matches": len(matches),
        "matches": matches,
    })


if __name__ == "__main__":
    main()
